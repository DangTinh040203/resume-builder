{
  "name": "resume-builder",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,css}\""
  },
  "devDependencies": {
    "@resume-builder/prettier-config": "workspace:*",
    "prettier": "^3.4.2",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "prettier": "@resume-builder/prettier-config",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.4"
}
