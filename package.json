{
  "name": "resume-builder",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:fe": "turbo run build --filter=@resume-builder/fe",
    "build:be": "turbo run build --filter=@resume-builder/be",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint --filter=@resume-builder/fe -- --fix && turbo run lint --filter=@resume-builder/be -- --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,css}\""
  },
  "devDependencies": {
    "@resume-builder/prettier-config": "workspace:*",
    "prettier": "^3.4.2",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "prettier": "@resume-builder/prettier-config",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.4"
}
