# Dependencies (reinstalled inside the image from the lockfile)
node_modules
**/node_modules

# Build output (rebuilt inside the image)
.next
**/.next
dist
**/dist
out
**/out
.turbo
**/.turbo
*.tsbuildinfo

# Env / secrets (FE public vars are passed as build args; never bake .env)
.env
.env.*
**/.env
**/.env.*
!**/.env.example

# VCS & agent/editor tooling
.git
.gitignore
.github
.agents
.claude
.vscode
.idea

# Docs & docker (not needed in the app image)
docs
docker

# Tests & coverage
coverage
**/coverage
**/__tests__
**/*.spec.ts
**/*.test.ts

# Logs & misc
*.log
npm-debug.log*
.DS_Store
