# ─── Server ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:3001

# ─── API ──────────────────────────────────────────────────────────────────
API_PREFIX=api
API_VERSION=1

# ─── Clerk (https://dashboard.clerk.com → API Keys / Webhooks) ──────────────
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/resume_builder_db?schema=public"
# Optional: direct (non-pooled) connection used by Prisma migrations.
# Set this when DATABASE_URL points at a pooler (e.g. Supabase port 6543).
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/resume_builder_db?schema=public"

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_NAMESPACE=resume-builder

# ─── Rate limiting ──────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=10

# ─── Google Gemini (https://aistudio.google.com → Get API Key) ──────────────
GEMINI_API_KEY=xxx
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
